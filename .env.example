# LocalShout website — environment template.
# Copy to `.env.local` and fill in real values (`.env.local` is gitignored).
#
# NEXT_PUBLIC_* vars are exposed to the browser. Everything else is server-only
# (route handlers / Server Components) and must NEVER be prefixed NEXT_PUBLIC_.

# ── Public API surface ───────────────────────────────────────────────────────
# Backend REST base as seen by the browser (includes the /api suffix the app calls).
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Socket.io origin (backend base WITHOUT /api — matches the mobile convention).
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# ── Third-party (public) keys ────────────────────────────────────────────────
# Google Maps JS API key (Explore map, campaign pins).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Cloudinary cloud name for building media URLs / unsigned widget config.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# Google OAuth *Web* client ID (sign in / sign up with Google on the website).
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# ── SEO / canonical ──────────────────────────────────────────────────────────
# Canonical public origin (no trailing slash) — used for canonical URLs, OG/Twitter
# tags, sitemap.ts, robots.ts, JSON-LD, and the blog RSS feed. Defaults to prod.
NEXT_PUBLIC_SITE_URL=https://www.localcreatorcrew.com

# ── Analytics (Phase 13) ─────────────────────────────────────────────────────
# Provider: "plausible" (cookieless, no consent needed), "ga4" (cookies → gated by
# the cookie-consent banner), or "none" (default — analytics fully off).
NEXT_PUBLIC_ANALYTICS_PROVIDER=none
# Plausible: the site domain (data-domain). Optional self-hosted script src override.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.tagged-events.js
# GA4 measurement ID (e.g. G-XXXXXXXXXX). Only used when provider=ga4.
NEXT_PUBLIC_GA4_ID=

# ── Dev data ─────────────────────────────────────────────────────────────────
# "true" → run against in-memory mocks (MSW, Phase 2) instead of the real backend.
NEXT_PUBLIC_USE_MOCKS=false

# ── Server-only ──────────────────────────────────────────────────────────────
# Long random string used to sign/encrypt the session cookies (Phase 3).
SESSION_COOKIE_SECRET=change-me-to-a-long-random-string
# Backend base URL as seen from THIS Next server (server→backend, includes /api).
# In Docker/prod this may differ from the public NEXT_PUBLIC_API_URL.
BACKEND_INTERNAL_URL=http://localhost:4000/api

# ── Transactional email — Resend (contact form) ──────────────────────────────
# The /api/contact route emails submissions to the support inbox. Same Resend
# account + verified domain as the backend, so the names match backend/.env:
#   1. API key from resend.com > API Keys → RESEND_API_KEY.
#   2. RESEND_FROM must be an address on a VERIFIED domain (resend.com > Domains).
# If either is blank, contact submissions are NOT emailed — the form still
# returns success and the route logs a dev warning (never the visitor's details).
RESEND_API_KEY=
RESEND_FROM="LocalShout <noreply@davnoot.com>"
# Where contact-form submissions land. The Privacy Policy routes GDPR/CCPA rights
# requests through this form, so this mailbox must be monitored.
CONTACT_TO_EMAIL=support@localcreatorcrew.com

# ── SEO publishing dashboard (private /seoteam) ──────────────────────────────
# The /seoteam dashboard lets a non-technical team publish blog posts that appear
# instantly on /blog. It uses ITS OWN MongoDB (not the external backend) and its
# own shared-password gate — all server-only (never NEXT_PUBLIC_).
#
# MongoDB connection string for the blog `Post` collection. Can point at the same
# Atlas cluster as the backend (use a distinct db/collection).
MONGODB_URI=
# Single shared password the SEO team types to log in to /seoteam.
SEO_DASHBOARD_PASSWORD=
# Cloudinary server credentials for the SEO-session-gated image upload signer
# (cover + inline images). Distinct from the browser-only cloud name above.
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Secret that signs the SEO session cookie. RECOMMENDED: set a dedicated, high-
# entropy value here so the SEO gate and the app's user-auth cookies don't share
# one secret. If unset, it falls back to SESSION_COOKIE_SECRET (above). Generate
# with: openssl rand -hex 32
SEO_SESSION_SECRET=

# ── Analytics Hub (private /analyticshub) ────────────────────────────────────
# Self-configuring analytics dashboard (GA4, Search Console, Meta Ads, Google
# Ads). All API credentials are entered IN the dashboard's settings page and
# stored AES-256-GCM encrypted in MongoDB (reuses MONGODB_URI above) — never here.
#
# Master secret: one 32-byte base64 value HKDF-expanded into the encryption key
# and the session-cookie HMAC key. Generate with:  openssl rand -base64 32
# (paste the raw 44-char output, no quotes). Changing it later orphans everything
# already stored. REQUIRED for /analyticshub to work.
ANALYTICSHUB_SECRET_KEY=
# Shared Google OAuth app (enables "Sign in with Google" for GA4 + Search Console;
# without these, only the service-account path is offered). One OAuth app can
# serve every deployment — add each domain's callback URL in Google Cloud:
#   https://<your-domain>/api/analyticshub/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- SMS auto-send — Twilio [Stage 15] ---------------------------------------
# NOTE: real values are SECRETS — put them in the backend's own untracked env
# (Collably/backend/.env), NEVER here. This is a committed template: placeholders only.
# From the Twilio Console → Account Dashboard → Account Info.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Sender — fill ONE of these (Messaging Service SID preferred):
#   Messaging → Services → your service → copy the MG… SID
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   …or a single purchased SMS number in E.164, e.g. +15551234567
TWILIO_FROM_NUMBER=+15551234567
# Account-wide monthly auto-SMS cap; 0 = unlimited.
TWILIO_MONTHLY_CAP=0